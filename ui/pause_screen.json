{
  "namespace": "pause",
  
  "pause_screen": {
    "gamepad_cursor": true,
    "absorbs_input": false,
    "force_render_below": true,
    "variables": [
      {
        "requires": "$ignore_edu_pause",
        "$screen_content": "pause.pause_screen_content_panel"
      },
      {
        "requires": "(not $ignore_edu_pause)",
        "$screen_content": "pause.pause_screen_content_panel"
      }
    ]
  },

  "panel_open_toggle@common_toggles.light_text_toggle": {
    "$toggle_view_binding_name": "open_toggle_pause",
    "$button_text": "set_hud.pause_computer_mode",
    "size": [ 62, 20 ],
    "offset": [ 5, 5 ],
    "layer": 100,
    "anchor_from": "top_left",
    "anchor_to": "top_left"
  },
  
  "return_button@common_buttons.light_text_button": {
    "$pressed_button_name": "button.menu_continue",
    "$button_text": "set_hud.pause_return",
    "size": [ 62, 20 ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 5, 5 ],
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "open_toggle_pause",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ]
  },
  
  "pause_screen_content_panel": {
    "type": "panel",
    "modal": true,
    "size": [ "100%", "100%" ],
    "controls": [      
      { "content@pause_screen_content": {} },
      { "return_button@return_button": {} }
    ]
  },
  
  "pause_screen_content": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          { "bg@common.screen_background": { "size": [ "100%", "100%" ] } },
          { "panel_open_toggle@panel_open_toggle": {} }
        ]
      }
    ],
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "open_toggle_pause",
        "source_property_name": "(not #toggle_state)",
        "target_property_name": "#visible"
      }
    ]
  }
}