{
  "rounded_durability_text_template": {
    "type": "label",
    "shadow": true,
    "font_size": "small",
    "font_type": "default",
    "text_alignment": "left",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "text": "$current_durability",
    "offset": [ "8%", -5 ],
    "bindings": [
      {
        "binding_name": "#item_durability_current_amount",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#item_durability_current_amount > $lower_durability_amount) and (#item_durability_current_amount < $upper_durability_amount))",
        "target_property_name": "#visible"
      }
    ]
  },

  "durability_bar_number": {
    "ignored": "(not $durability_bar_required)",
    "$durability_bar_offset|default": [ 0, 5 ],
    "offset": "$durability_bar_offset",
    "type": "panel",
    "bindings": [
      {
        "binding_name": "#item_durability_total_amount",
        "binding_name_override": "#progress_bar_total_amount",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#progress_bar_total_amount = 0))",
        "target_property_name": "#visible"
      }
    ],
